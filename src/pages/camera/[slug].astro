---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SpecTable from '../../components/SpecTable.astro';
import { CATEGORY_LABEL } from '../../content.config';

export async function getStaticPaths() {
  const items = await getCollection('camera');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}
const { item } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title={`${item.data.name} — novaX Catalog`} activeCategory="camera">
  <section class="detail-hero">
    <div class="container">
      <div class="crumbs"><a href={`${base}/#camera`}>{CATEGORY_LABEL.camera}</a></div>
      <div class="meta">Product · Catalog 2026</div>
      <h1>{item.data.name}</h1>
      {item.data.tagline && <div class="tag">{item.data.tagline}</div>}
    </div>
  </section>

  <section class="detail-body">
    <div class="container">
      <div class="row">
        {item.data.image && (
          <div class="imgwrap"><img src={`${base}${item.data.image}`} alt={item.data.name} /></div>
        )}
        <SpecTable specs={item.data.specs} />
      </div>
    </div>
  </section>
</Layout>
