---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { statSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Gather every firmware asset that opts into the web Update tool (has method + webPath).
const all = [
  ...await getCollection('fc'),
  ...await getCollection('gnss'),
  ...await getCollection('esc'),
  ...await getCollection('motor'),
  ...await getCollection('camera'),
];
type Row = { product: string; version: string; kind: string; method: string; path: string; file: string; size: string; family: string; mcu: string };
// File size in KB, read from the public/ asset at build time.
function kbOf(webPath: string): string {
  try {
    const p = fileURLToPath(new URL('../../public' + webPath, import.meta.url));
    return Math.round(statSync(p).size / 1024).toLocaleString('en-US') + ' KB';
  } catch { return ''; }
}
const rows: Row[] = [];
for (const e of all) {
  // The DFU chip guard needs each board's MCU family (F4/F7/H7), read from its specs.
  const mcu = e.data.specs?.find((s) => s.key === 'MCU')?.value || '';
  const family = /H7/i.test(mcu) ? 'H7' : /F7/i.test(mcu) ? 'F7' : /F4/i.test(mcu) ? 'F4' : '';
  for (const fw of e.data.firmware ?? []) {
    if (fw.method && fw.webPath) {
      rows.push({ product: e.data.name, version: fw.version, kind: fw.kind, method: fw.method, path: base + fw.webPath, file: fw.webPath.split('/').pop() || '', size: kbOf(fw.webPath), family, mcu });
    }
  }
}
// Sort alphabetically, then numerically (natural order): AF-F4 < AF-F7 < AF-H7 < AF-H7E.
rows.sort((a, b) =>
  a.product.localeCompare(b.product, 'en', { numeric: true, sensitivity: 'base' })
  || a.version.localeCompare(b.version, 'en', { numeric: true })
);
const fwRows = rows.filter((r) => r.method !== 'dfu');
const dfuRows = rows.filter((r) => r.method === 'dfu');
---
<Layout title="Firmware Update — novaX Catalog" activeCategory="update">
  <section class="detail-body">
    <div class="container update-tool">
      <div class="crumb">Update</div>
      <h1>Firmware Update</h1>

      <div class="seg" role="tablist">
        <button data-mode="fw" class="on">⚡ Firmware Update <span class="tag">· normal</span></button>
        <button data-mode="dfu">🛠 DFU Recovery <span class="tag">· blank / bricked</span></button>
      </div>

      <p class="mode-note" data-note="fw">Normal update over USB — device stays running, no jumper. Switch to <b>DFU Recovery</b> only if the board is blank or won't boot.</p>
      <p class="mode-note" data-note="dfu" hidden>Low-level recovery: re-flashes bootloader + app. Hold <b>BOOT0</b> and plug in USB, then connect. Windows needs a one-time WinUSB driver (Zadig).</p>

      <div class="banner" data-banner="fw">
        <div class="step"><b>① Connect</b>Just plug in USB-C. No BOOT0 jumper.</div>
        <div class="step"><b>② Browser</b>Chrome or Edge (desktop). Uses Web Serial.</div>
        <div class="step good"><b>③ Driver</b>None — standard USB serial (CDC).</div>
      </div>
      <div class="banner" data-banner="dfu" hidden>
        <div class="step"><b>① Enter DFU</b>Hold BOOT0 and plug in USB, then release.</div>
        <div class="step"><b>② Browser</b>Chrome or Edge (desktop). Uses WebUSB.</div>
        <div class="step warn"><b>③ Windows</b>One-time WinUSB driver via Zadig.</div>
      </div>

      <div class="row-connect">
        <button id="connect" class="btn btn-line">🔌 Connect</button>
        <button id="softdfu" class="btn btn-line" title="버튼 없는 보드: 앱에서 소프트웨어로 ROM DFU 진입 (펌웨어 ≥ v0.2.2 / T10 v0.3.2)">🛠 Software DFU</button>
        <span id="status" class="chip">Not connected</span>
      </div>

      <div class="card">
        <div class="head">Select firmware <span id="listmode">(application image)</span></div>
        <table class="cfg-table fwsel">
          <thead><tr><th style="width:34px"></th><th>Product</th><th>Version</th><th>File</th></tr></thead>
          <tbody data-list="fw">
            {fwRows.length === 0 && <tr><td colspan="4" class="empty">No web-flashable app firmware yet.</td></tr>}
            {fwRows.map((r, i) => (
              <tr class="fwrow" data-method={r.method} data-path={r.path} data-name={`${r.product} ${r.version}`} data-family={r.family} data-mcu={r.mcu}>
                <td><span class="rad" data-radio></span></td>
                <td class="pname">{r.product}</td><td>{r.version}</td>
                <td><code>{r.file}</code> <span class="mtag">{r.method}</span>{r.size && <span class="fsize">{r.size}</span>}</td>
              </tr>
            ))}
          </tbody>
          <tbody data-list="dfu" hidden>
            {dfuRows.length === 0 && <tr><td colspan="4" class="empty">No web-flashable recovery image yet.</td></tr>}
            {dfuRows.map((r) => (
              <tr class="fwrow" data-method={r.method} data-path={r.path} data-name={`${r.product} ${r.version}`} data-family={r.family} data-mcu={r.mcu}>
                <td><span class="rad" data-radio></span></td>
                <td class="pname">{r.product}</td><td>{r.version}</td>
                <td><code>{r.file}</code> <span class="mtag">{r.method}</span>{r.size && <span class="fsize">{r.size}</span>}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <label class="drop" id="drop">… or drag &amp; drop a firmware file here (<span data-droptypes>.apj / .bin</span>)
          <input type="file" id="file" hidden /></label>
      </div>

      <div class="actions">
        <button id="flash" class="btn btn-primary" disabled>⚡ Update firmware</button>
        <button id="reloadpage" class="btn btn-line" type="button" title="Clear caches + refresh the page (F5) — releases the USB/COM port and re-detects the device">🔄 Reload</button>
        <span class="hint" id="flowhint">reboot to bootloader → erase → program → verify → boot</span>
      </div>

      <div class="log" id="log"><div class="bar"><i id="bar"></i></div><div id="loglines"><span class="pend">Connect a device and pick firmware to begin.</span></div></div>
    </div>
  </section>
</Layout>

<style>
  .update-tool { max-width: 960px; }
  .update-tool [hidden] { display: none !important; } /* author .banner{display:flex} would otherwise override UA [hidden] */
  .update-tool .crumb { font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: var(--ink-4); }
  .update-tool h1 { font-size: 30px; margin: 8px 0 18px; }
  .seg { display: inline-flex; border: 1px solid var(--line); border-radius: 10px; overflow: hidden; margin-bottom: 8px; }
  .seg button { border: 0; background: #fff; padding: 12px 20px; font-size: 14px; font-weight: 600; color: var(--ink-3); cursor: pointer; }
  .seg button.on { background: var(--blue, #1a73e8); color: #fff; }
  .seg .tag { font-size: 11px; font-weight: 500; opacity: .8; }
  .mode-note { font-size: 12.5px; color: var(--ink-4); margin: 4px 0 22px; }
  .banner { display: flex; gap: 14px; background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 16px 18px; margin-bottom: 22px; }
  .banner .step { flex: 1; font-size: 12.5px; color: var(--ink-3); }
  .banner .step b { display: block; color: var(--ink); font-size: 13px; margin-bottom: 3px; }
  .banner .good { color: #127a2e; } .banner .warn { color: #b26a00; }
  .row-connect { display: flex; align-items: center; gap: 14px; margin-bottom: 22px; }
  .btn { border: 0; border-radius: 8px; padding: 11px 18px; font-size: 13.5px; font-weight: 600; cursor: pointer; }
  .btn-line { background: #fff; border: 1px solid #cfcfcf; color: var(--ink); }
  .btn-primary { background: var(--blue, #1a73e8); color: #fff; }
  .btn-primary[disabled] { background: #c7d6f3; cursor: not-allowed; }
  .chip { font-size: 12.5px; padding: 5px 11px; border-radius: 20px; border: 1px solid var(--line); color: var(--ink-3); }
  .chip.ok { color: #127a2e; border-color: #bfe3c8; background: #f1faf3; }
  .chip.err { color: #b22; border-color: #f0c4c4; background: #fcf2f2; }
  .fwsel .fwrow { cursor: pointer; }
  .fwsel .fwrow.sel td { background: #f3f8ff; }
  .fwsel .empty { color: var(--ink-4); text-align: center; }
  .rad { width: 15px; height: 15px; border-radius: 50%; border: 2px solid #bbb; display: inline-block; vertical-align: middle; }
  .fwrow.sel .rad { border-color: var(--blue, #1a73e8); box-shadow: inset 0 0 0 3px var(--blue, #1a73e8); }
  .mtag { font-size: 10.5px; font-weight: 700; padding: 2px 7px; border-radius: 5px; background: #eef; color: #3651c9; margin-left: 6px; }
  .drop { display: block; margin: 4px 18px 16px; padding: 14px; border: 1px dashed var(--line); border-radius: 8px; color: var(--ink-4); font-size: 12.5px; text-align: center; cursor: pointer; }
  .drop.over { border-color: var(--blue, #1a73e8); color: var(--blue, #1a73e8); }
  .actions { display: flex; align-items: center; gap: 16px; margin: 16px 0; }
  .actions .hint { font-size: 12.5px; color: var(--ink-4); }
  .log { background: #0e0f12; color: #cdd3da; border-radius: 10px; padding: 14px 16px; font-family: ui-monospace, Menlo, monospace; font-size: 12.5px; line-height: 1.7; }
  .log .bar { height: 8px; border-radius: 5px; background: #2a2d33; overflow: hidden; margin-bottom: 10px; }
  .log .bar i { display: block; height: 100%; width: 0; background: var(--blue, #1a73e8); transition: width .15s; }
  .log .ok { color: #5fd08a; } .log .pend { color: #6f7888; } .log .err { color: #ef6f6f; }
  .fsize { margin-left: 8px; color: var(--ink-4, #888); font-size: 12px; white-space: nowrap; }
</style>

<script>
  import { STM32Dfu } from '../scripts/update/dfu';
  import { parseIntelHex } from '../scripts/update/intel-hex';
  import { Px4Updater } from '../scripts/update/serial-px4';
  import { parseApj, parseBin } from '../scripts/update/apj';

  const BUILD = '2026-06-19 · Software DFU button (app→param4=99→ROM DFU); F405 layout fallback for DFU chip detect';
  const $ = (s: string) => document.querySelector(s) as HTMLElement;
  const logEl = $('#loglines'), barEl = $('#bar') as HTMLElement, statusEl = $('#status');
  const connectBtn = $('#connect') as HTMLButtonElement, flashBtn = $('#flash') as HTMLButtonElement;
  let mode: 'fw' | 'dfu' = 'fw';
  let conn: any = null;
  let selectedPath: string | null = null;
  let droppedFile: File | null = null;
  let selectedFamily: string | null = null; // F4/F7/H7 of the picked catalog firmware (DFU guard)
  let selectedName: string | null = null;

  const log = (m: string, cls = '') => { const d = document.createElement('div'); if (cls) d.className = cls; d.textContent = m; logEl.appendChild(d); logEl.scrollTop = 1e9; };
  const progress = (done: number, total: number) => { barEl.style.width = total ? `${Math.round((done / total) * 100)}%` : '0'; };
  const setStatus = (t: string, cls = '') => { statusEl.textContent = t; statusEl.className = 'chip ' + cls; };
  const refreshFlashEnabled = () => { flashBtn.disabled = !(conn && (selectedPath || droppedFile)); };

  // Browsers cannot silently auto-pick a port on first use (security), but a device the
  // user has authorized before can be reopened with no picker. Try that for the active mode.
  async function autoDetect() {
    if (conn) return;
    if (mode === 'dfu') {
      // WebUSB: a granted DFU device can be reopened without a picker (no exclusive COM seized).
      try {
        const c = await STM32Dfu.autoConnect();
        if (c) {
          conn = c;
          setStatus('● ' + (c as any).chipLabel(), 'ok');
          log('Reconnected to a previously authorized DFU device. Detected chip: ' + (c as any).chipLabel(), 'ok');
          refreshFlashEnabled();
        }
      } catch { /* none granted — use Connect */ }
      return;
    }
    // Serial: do NOT silently open a COM port. Opening blindly seizes whatever port was
    // granted first (maybe not even this board) and would falsely report a verified link —
    // it also locks the COM so nothing else (CLI, this probe) can use it. Just hint.
    try {
      if (await Px4Updater.hasGrantedPort()) setStatus('🔌 USB port detected — click Connect', 'ok');
    } catch { /* ignore */ }
  }
  log('Web Updater build ' + BUILD, 'pend');
  autoDetect();

  // "Reload" button = clear caches + page refresh (F5). First purge any Cache-Storage entries
  // and unregister service workers (best-effort — a static site usually has none), then do a
  // cache-busting navigation: the fresh load bypasses the HTTP cache (picks up the latest
  // build), releases the exclusively-held COM/USB port, and re-detects the device. ?mode keeps
  // FW/DFU across the reload so it re-detects on the right transport.
  $('#reloadpage').addEventListener('click', async (ev) => {
    const btn = ev.currentTarget as HTMLButtonElement;
    btn.disabled = true; btn.textContent = '🔄 Reloading…';
    try { if (self.caches) { const ks = await caches.keys(); await Promise.all(ks.map((k) => caches.delete(k))); } } catch { /* ignore */ }
    try {
      const sw = (navigator as any).serviceWorker;
      if (sw) { const rs = await sw.getRegistrations(); await Promise.all(rs.map((r: any) => r.unregister())); }
    } catch { /* ignore */ }
    location.replace(location.pathname + '?mode=' + mode + '&r=' + Date.now());
  });

  // ---- mode toggle ----
  document.querySelectorAll<HTMLButtonElement>('.seg button').forEach((b) => b.addEventListener('click', () => {
    document.querySelectorAll('.seg button').forEach((x) => x.classList.remove('on'));
    b.classList.add('on');
    mode = (b.dataset.mode as 'fw' | 'dfu');
    document.querySelectorAll('[data-note]').forEach((n) => (n as HTMLElement).hidden = (n as HTMLElement).dataset.note !== mode);
    document.querySelectorAll('[data-banner]').forEach((n) => (n as HTMLElement).hidden = (n as HTMLElement).dataset.banner !== mode);
    document.querySelectorAll('[data-list]').forEach((n) => (n as HTMLElement).hidden = (n as HTMLElement).dataset.list !== mode);
    $('#listmode').textContent = mode === 'dfu' ? '(bootloader + app image)' : '(application image)';
    $('#flowhint').textContent = mode === 'dfu' ? 'erase → write → verify → leave DFU' : 'reboot to bootloader → erase → program → verify → boot';
    $('#flash').textContent = mode === 'dfu' ? '⚡ Flash (DFU)' : '⚡ Update firmware';
    ($('[data-droptypes]') as HTMLElement).textContent = mode === 'dfu' ? '.hex' : '.apj / .bin';
    ($('#softdfu') as HTMLElement).hidden = (mode !== 'fw'); // software-DFU entry is a serial(app) action
    // reset connection/selection on mode switch (different transport)
    if (conn) { conn.close?.(); conn = null; }
    selectedPath = null; droppedFile = null;
    document.querySelectorAll('.fwrow').forEach((r) => r.classList.remove('sel'));
    setStatus('Not connected'); refreshFlashEnabled();
    autoDetect();
  }));

  // ---- Software DFU (no BOOT0 button): from the running app (Web Serial), send the
  // ArduPilot boot-to-DFU magic; the board resets into the ST ROM DFU (0483:DF11). Then the
  // user switches to DFU Recovery (WebUSB) to flash. Requires firmware whose bootloader has
  // ENABLE_DFU_BOOT (novaX ≥ v0.2.2 / T10 ≥ v0.3.2). ----
  $('#softdfu').addEventListener('click', async () => {
    if (mode !== 'fw') return;
    if (!conn) { setStatus('Connect first (Firmware Update)', 'err'); return; }
    try {
      log('Software DFU: sending boot-to-DFU magic (param4=99) over serial …', 'pend');
      await (conn as InstanceType<typeof Px4Updater>).enterRomDfu(log);
      conn = null; refreshFlashEnabled();
      log('→ Now click "DFU Recovery", then Connect, pick the *_with_bl.hex, and Flash.', 'ok');
      setStatus('Entered DFU — switch to DFU Recovery to flash', 'ok');
    } catch (e: any) {
      log('Software DFU failed: ' + (e?.message || e) + ' (needs firmware ≥ v0.2.2 / T10 v0.3.2)', 'err');
      setStatus('Software DFU failed', 'err');
    }
  });

  // After a Reload, restore the saved mode (carried in ?mode=…) so USB re-detects on the
  // right transport — WebSerial for FW, WebUSB for DFU.
  if (new URLSearchParams(location.search).get('mode') === 'dfu') {
    (document.querySelector('.seg button[data-mode="dfu"]') as HTMLButtonElement)?.click();
  }

  // ---- row selection ----
  document.querySelectorAll<HTMLElement>('.fwrow').forEach((row) => row.addEventListener('click', () => {
    row.parentElement!.querySelectorAll('.fwrow').forEach((r) => r.classList.remove('sel'));
    row.classList.add('sel');
    selectedPath = row.dataset.path || null; droppedFile = null;
    selectedFamily = row.dataset.family || null; selectedName = row.dataset.name || null;
    refreshFlashEnabled();
  }));

  // ---- drag & drop ----
  const drop = $('#drop'), fileInput = $('#file') as HTMLInputElement;
  drop.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) pickFile(fileInput.files[0]); });
  ['dragover', 'dragenter'].forEach((ev) => drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add('over'); }));
  ['dragleave', 'drop'].forEach((ev) => drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.remove('over'); }));
  drop.addEventListener('drop', (e) => { const f = (e as DragEvent).dataTransfer?.files?.[0]; if (f) pickFile(f); });
  function pickFile(f: File) {
    droppedFile = f; selectedPath = null;
    selectedFamily = null; selectedName = null; // dropped file → no catalog family to match against
    document.querySelectorAll('.fwrow').forEach((r) => r.classList.remove('sel'));
    log(`File selected: ${f.name} (${f.size} bytes)`);
    refreshFlashEnabled();
  }

  // ---- connect ----
  connectBtn.addEventListener('click', async () => {
    try {
      if (mode === 'dfu') {
        conn = await STM32Dfu.connect();
        setStatus('● ' + conn.chipLabel(), 'ok');
        log('Connected. Detected chip: ' + conn.chipLabel(), 'ok');
      } else {
        conn = await Px4Updater.connect();
        setStatus('● serial port connected', 'ok');
        log('Connected.', 'ok');
      }
    } catch (e: any) { setStatus('connect failed', 'err'); log(String(e?.message || e), 'err'); conn = null; }
    refreshFlashEnabled();
  });

  // ---- load firmware bytes (same-origin path or dropped file) ----
  async function loadBytes(): Promise<{ text?: string; buf?: ArrayBuffer; name: string }> {
    if (droppedFile) {
      const name = droppedFile.name;
      if (name.endsWith('.hex') || name.endsWith('.apj')) return { text: await droppedFile.text(), name };
      return { buf: await droppedFile.arrayBuffer(), name };
    }
    const res = await fetch(selectedPath!);
    if (!res.ok) throw new Error(`fetch ${selectedPath} → ${res.status}`);
    const name = selectedPath!.split('/').pop() || '';
    if (name.endsWith('.hex') || name.endsWith('.apj')) return { text: await res.text(), name };
    return { buf: await res.arrayBuffer(), name };
  }

  // ---- flash ----
  flashBtn.addEventListener('click', async () => {
    flashBtn.disabled = true;
    try {
      const src = await loadBytes();
      log(`Loaded ${src.name}`, 'ok');
      if (mode === 'dfu') {
        const text = src.text ?? new TextDecoder().decode(new Uint8Array(src.buf!));
        const hex = parseIntelHex(text);
        log(`HEX 0x${hex.minAddress.toString(16)}–0x${hex.maxAddress.toString(16)}, ${hex.totalBytes} bytes`);
        // ---- chip guard: stop a wrong-chip flash before erasing anything ----
        const info = (conn as InstanceType<typeof STM32Dfu>).flashInfo();
        log(`Connected chip: ${(conn as InstanceType<typeof STM32Dfu>).chipLabel()}`);
        // A) capacity: the image must fit the device's flash (blocks bigger-chip firmware).
        if (hex.maxAddress > info.base + info.totalSize) {
          throw new Error(`Chip mismatch — flash aborted. This firmware writes up to 0x${hex.maxAddress.toString(16)}, but the connected chip's flash is only ${(info.totalSize / 1024) | 0} KB (up to 0x${(info.base + info.totalSize).toString(16)}). It is firmware for a larger chip.`);
        }
        // B) family: a catalog firmware knows its target family — block cross-family flashes.
        if (selectedFamily && info.family !== 'unknown' && selectedFamily !== info.family) {
          throw new Error(`Chip mismatch — flash aborted. The selected firmware is for STM32${selectedFamily}-class (${selectedName}), but the connected board is STM32${info.family}-class. Wrong board.`);
        }
        if (selectedFamily && info.family === 'unknown') {
          log('⚠ Could not auto-detect chip family — capacity check only. Verify the board yourself.', 'pend');
        }
        if (droppedFile) {
          log('Dropped file — catalog chip match skipped (capacity check only). Verify this is the right board.', 'pend');
        }
        await (conn as InstanceType<typeof STM32Dfu>).flash(hex, log, progress);
      } else {
        const img = src.name.endsWith('.apj') ? await parseApj(src.text!) : parseBin(src.buf ?? new TextEncoder().encode(src.text!).buffer);
        log(`App image ${img.bytes.length} bytes${img.boardId ? ` (board ID ${img.boardId})` : ''}`);
        if (!img.boardId && selectedName) log('⚠ This .bin has no board ID — only the capacity check applies. Verify the board yourself.', 'pend');
        await (conn as InstanceType<typeof Px4Updater>).flash(img.bytes, log, progress, img.boardId);
      }
      progress(1, 1);
      log('✓ Done. Device rebooting.', 'ok');
    } catch (e: any) { log('✗ ' + String(e?.message || e), 'err'); }
    flashBtn.disabled = false;
  });
</script>
