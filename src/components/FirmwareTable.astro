---
interface FirmwareItem {
  kind: string;
  file: string;
  version: string;
  date?: string;
  size?: string;
  sha256?: string;
  notes?: string;
}
interface Props {
  items: FirmwareItem[];
  productName: string;
}
const { items, productName } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// `file` accepts either a site-relative path (/firmware/...) served from public/,
// or a full external URL such as a GitHub Release asset download link.
const isExternal = (f: string) => /^https?:\/\//.test(f);
const hrefOf = (f: string) => (isExternal(f) ? f : `${base}${f}`);
---
<div class="firmware-list">
  <table class="fw-table">
    <thead>
      <tr>
        <th>Type</th>
        <th>Version</th>
        <th>Date</th>
        <th>Size</th>
        <th>Download</th>
      </tr>
    </thead>
    <tbody>
      {items.map((it) => (
        <tr>
          <td>
            <div class="fw-kind">{it.kind}</div>
            {it.notes && <div class="fw-notes">{it.notes}</div>}
          </td>
          <td>{it.version}</td>
          <td>{it.date ?? '—'}</td>
          <td>{it.size ?? '—'}</td>
          <td>
            <a class="fw-dl" href={hrefOf(it.file)} download aria-label={`Download ${productName} ${it.kind} ${it.version}`}>
              {it.file.split('/').pop()}
            </a>
            {it.sha256 && <div class="fw-sha">SHA-256: <code>{it.sha256}</code></div>}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .firmware-list { margin-top: 8px; }
  .fw-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .fw-table th, .fw-table td {
    text-align: left;
    padding: 12px 14px;
    border-bottom: 1px solid #eee;
    vertical-align: top;
  }
  .fw-table th {
    font-weight: 600;
    color: #555;
    background: #fafafa;
    border-bottom: 1px solid #e2e2e2;
  }
  .fw-kind { font-weight: 600; color: #222; }
  .fw-notes { color: #777; font-size: 12.5px; margin-top: 3px; }
  .fw-dl {
    display: inline-block;
    color: #1a73e8;
    text-decoration: none;
    word-break: break-all;
  }
  .fw-dl:hover { text-decoration: underline; }
  .fw-sha {
    margin-top: 4px;
    font-size: 11.5px;
    color: #888;
    word-break: break-all;
  }
  .fw-sha code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
</style>
