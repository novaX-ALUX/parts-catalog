---
interface Row { throttle: string; thrust?: string }
interface Props {
  rows: Row[];
  propeller: string;
}
const { rows, propeller } = Astro.props;

const points = rows
  .map((r) => ({
    x: parseFloat(r.throttle),
    y: r.thrust && r.thrust !== '—' ? parseFloat(r.thrust) : null
  }))
  .filter((p) => !isNaN(p.x));

const valid = points.filter((p) => p.y !== null) as { x: number; y: number }[];
const hasData = valid.length >= 2;

const W = 560;
const H = 220;
const pad = { l: 48, r: 16, t: 16, b: 28 };
const innerW = W - pad.l - pad.r;
const innerH = H - pad.t - pad.b;

const maxY = hasData ? Math.max(...valid.map((p) => p.y)) : 1;
function niceCeil(v: number): number {
  if (v <= 0) return 1;
  const mag = Math.pow(10, Math.floor(Math.log10(v)));
  const norm = v / mag;
  let nice: number;
  if (norm <= 1) nice = 1;
  else if (norm <= 2) nice = 2;
  else if (norm <= 5) nice = 5;
  else nice = 10;
  return nice * mag;
}
const niceMax = niceCeil(maxY) || 1;

function sx(x: number) { return pad.l + (x / 100) * innerW; }
function sy(y: number) { return pad.t + innerH - (y / niceMax) * innerH; }

const path = valid.map((p, i) => `${i === 0 ? 'M' : 'L'} ${sx(p.x)} ${sy(p.y)}`).join(' ');

const yTicks = [0, 0.25, 0.5, 0.75, 1].map((f) => Math.round(niceMax * f));
const xTicks = [0, 20, 40, 60, 80, 100];
---
<div class="chart-wrap">
  <div class="title">Propeller {propeller} · Thrust (g) vs Throttle (%)</div>
  {hasData ? (
    <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="xMidYMid meet">
      {yTicks.map((v) => (
        <Fragment>
          <line class="grid-line" x1={pad.l} x2={W - pad.r} y1={sy(v)} y2={sy(v)} />
          <text class="label" x={pad.l - 8} y={sy(v) + 3} text-anchor="end">{v}</text>
        </Fragment>
      ))}
      {xTicks.map((v) => (
        <text class="label" x={sx(v)} y={H - 8} text-anchor="middle">{v}%</text>
      ))}
      <line class="axis" x1={pad.l} y1={pad.t} x2={pad.l} y2={H - pad.b} />
      <line class="axis" x1={pad.l} y1={H - pad.b} x2={W - pad.r} y2={H - pad.b} />
      <path class="data-line" d={path} />
      {valid.map((p) => (
        <circle class="data-pt" cx={sx(p.x)} cy={sy(p.y)} r="3.5" />
      ))}
    </svg>
  ) : (
    <div style="padding: 32px 8px; color: var(--ink-4); font-size: 12px; text-align: center;">
      Full curve TBD · only peak measurement available.
    </div>
  )}
</div>
